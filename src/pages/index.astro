---
const siteTitle = "Busshouji";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoMeta from "../components/SeoMeta.astro";
import StructuredData from "../components/StructuredData.astro";
import "../styles/global.css";
import { getCollection } from "astro:content";
import {
	getOrganizationStructuredData,
	getWebSiteStructuredData,
} from "../utils/structuredData";

const months = Array.from({ length: 12 }, (_, i) => i + 1);
const pageDescription =
	"佛性寺の概要、お知らせ、年間行事をご紹介しています。ご参拝前の最新情報もご確認いただけます。"
;
const news = await getCollection("news");
const latestNews = news
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
	.slice(0, 3);
const events = await getCollection("events");
const eventsByMonth = events.reduce(
	(acc, entry) => {
		const month = entry.data.month;
		acc[month] = entry.data.events.map((item) => ({
			title: item.title,
			desc: item.summary,
			// image: item.image
		}));
		return acc;
	},
	{} as Record<number, { title: string; desc: string }[]>
);
const indexStructuredData = [
	getOrganizationStructuredData(Astro.site),
	getWebSiteStructuredData(Astro.site),
];

---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<SeoMeta
			title={siteTitle}
			pathname={Astro.url.pathname}
			site={Astro.site}
			description={pageDescription}
		/>
		<StructuredData data={indexStructuredData} />
		<title>{siteTitle}</title>
	</head>
	<body>
		<Header />

		<main>
			<section class="hero" aria-label="メインビジュアル">
				<img src="/images/hero/home-hero.webp" alt="ヒーロー画像" loading="eager" />
				<div class="hero-overlay">
					<p class="hero-subtitle">Busshouji WEBSITE</p>
					<h1>佛性寺の魅力を、静かに、丁寧に。</h1>
					<p>
						伝統と革新、
						厳粛と安心、
						出会いと別れ、
						その全てを重んじ育む
					</p>
				</div>
			</section>

			<div class="content-wrap">
				<section id="overview" class="info-section">
					<figure class="media media-overview">
						<img src="/images/other/image.webp" alt="佛性寺の概要イメージ" loading="lazy" />
					</figure>
					<div class="info-text">
						<p class="section-label">Overview</p>
						<h2>概要</h2>
						<p>
							佛性寺は、滋賀県彦根市に本堂を構える浄土真宗本願寺派の寺院です。<br>
							開祖 親鸞聖人の教えや宗門の伝統を重んじ、かつ現代的な新しい価値観にもより添う、人と人とが笑顔で交流できるようなお寺を目標に活動しています。<br>
							地域に深く根付き、地域と共に歩んできたお寺ですが、遠方の方や、これまで当寺をご存知なかった方々とのご縁も大事にさせていただきたく思っております。<br>
							<br>
							葬儀や仏事に関するご依頼やご質問、仏教に関する素朴な疑問やお悩み相談等、なんでも構いません。<br>
							何かご用があれば、下記のメールアドレスまでお問い合わせください。
						</p>
					</div>
				</section>

				<section id="news" class="info-section">
					<div class="info-text">
						<p class="section-label">News</p>
						<h2>お知らせ</h2>
						{latestNews.length === 0 ? (
							<p class="news-empty">現在、お知らせはありません。</p>
						) : (
							<ul class="news-list">
								{latestNews.map((item) => (
									<li>
										<time datetime={item.data.date.toISOString().slice(0, 10)}>
											{item.data.date.toISOString().slice(0, 10).replaceAll("-", "/")}
										</time>
										<a href={`/news/${item.slug}`}>{item.data.title}</a>
									</li>
								))}
							</ul>
						)}
						<a class="news-link" href="/news">お知らせ一覧へ</a>
					</div>
					<figure class="media media-news">
						<img src="/images/other/image-2.webp" alt="お知らせイメージ" loading="lazy" />
					</figure>
				</section>

				<section id="events" class="events-section">
					<figure class="events-hero">
						<img src="/images/other/image.webp" alt="年間行事イメージ" loading="lazy" />
					</figure>
					<div class="events-content ">
						<p class="section-label">Annual Events</p>
						<h2>年間行事</h2>
						<ul class="events-list">
							{months.map((month) => {
								const items = eventsByMonth[month] ?? [];
								return items.length > 0 ?
								(
									<li>
										{items.map((item) => (
											<a class="event-month" href={`/events#month=${month}`}><span >{month}月</span></a>
											<div class="event-body">
												<h5 class="event-title">{item.title}</h5>
												<p class="event-desc">
													{item.desc}
												</p>
											</div>
										))}
									</li>
								)
								:
								null
								;
							})}
						</ul>
						<a class="news-link" href="/events">年間行事 詳しくはコチラ</a>
					</div>
				</section>
			</div>
		</main>

		<Footer />
	</body>
</html>

<script>
	const sections = document.querySelectorAll(".content-wrap section");

	if ("IntersectionObserver" in window) {
		const observer = new IntersectionObserver(
			(entries, obs) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						// obs.unobserve(entry.target);
					} else {
						entry.target.classList.remove("is-visible");
					}
				});
			},
			{
				threshold: 0.15
			}
		);

		sections.forEach((section) => {
			section.classList.add("js-reveal");
			observer.observe(section);
		});
	}
</script>

<style>
	:root {
		color: #1f2b24;
		background-color: var(--color-bg);
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		background: linear-gradient(180deg, #f8f4ed 0%, var(--color-bg) 40%, #ebe7df 100%);
	}

	main {
		padding-top: 80px;
	}

	.hero {
		position: relative;
		width: 100%;
		height: 640px;
		overflow: hidden;
	}

	.hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		display: block;
		transform: scale(1.06);
		animation: heroZoomIn 2s ease forwards;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0 80px 76px;
		background: linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.4) 65%, rgba(0, 0, 0, 0.58) 100%);
		color: var(--color-white);
		animation: heroOverlaySlide 0.9s ease forwards;
	}

	.hero-subtitle {
		margin: 0;
		font-size: 0.75rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		opacity: 0.9;
	}

	h1 {
		margin: 0.8rem 0 1rem;
		font-size: clamp(2rem, 3.3vw, 3rem);
		letter-spacing: 0.05em;
		line-height: 1.3;
	}

	.hero-overlay p {
		margin: 0;
		font-size: 1rem;
		line-height: 1.9;
	}

	@keyframes heroZoomIn {
		from {
			transform: scale(1.1);
		}
		to {
			transform: scale(1);
		}
	}

	@keyframes heroOverlaySlide {
		from {
			transform: translateX(-40px);
		}
		to {
			transform: translateX(0);
		}
	}

	.content-wrap {
		width: min(1120px, calc(100% - 80px));
		margin: 100px auto 100px;
		display: grid;
		gap: 200px;
	}

	.info-section {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: start;
		gap: 40px;
		padding: 0;
	}

	.info-section.js-reveal {
		transform: scale(0.75);
		transition: transform 0.6s ease;
	}

	.info-section.js-reveal.is-visible {
		transform: scale(1);
	}

	.events-section {
		display: grid;
		gap: 32px;
	}

	.events-hero {
		margin: 0;
		width: 100vw;
		height: 220px;
		overflow: hidden;
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
	}

	.events-hero img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		display: block;
	}

	.events-content {
		width: min(1120px, calc(100% - 50px));
		margin: 260px auto 0 auto;
	}

	@media (max-width: 768px) {
		.events-content {
			width: min(1120px, 100%);
		}
	}

	.section-label {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: #7e6d52;
	}

	h2 {
		margin: 0.65rem 0 1rem;
		font-size: 2rem;
		letter-spacing: 0.05em;
		color: var(--color-text);
	}

	.info-text {
		margin: auto 0;
	}

	.info-text p, .events-content p {
		margin: 0;
		font-size: 1rem;
		line-height: 2;
		color: var(--color-text);
	}

	.news-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.news-list li {
		padding: 25px 0;
		border-bottom: 1px solid rgba(84, 70, 50, 0.3);
	}

	.news-list time {
		display: block;
		font-size: 15px;
		letter-spacing: 0.08em;
		color: #112e1e;
		/* margin-bottom: 5px; */
	}

	.news-list a {
		display: flex;
		margin: 0;
		font-size: 1.3rem;
		line-height: 1.9;
		color: var(--color-text);
		text-decoration: none;
		transition: color 0.2s ease, transform 0.2s ease;
	}

	.news-empty {
		margin: 0;
		font-size: 1rem;
		line-height: 1.9;
		color: var(--color-text);
	}

	.news-link {
		display: flex;
		justify-content: end;
		align-items: center;
		align-self: flex-start;
		gap: 0.4rem;
		margin-top: 50px;
		font-size: 0.95rem;
		text-decoration: none;
		color: var(--color-text);
		letter-spacing: 0.08em;
		transition: color 0.2s ease, transform 0.2s ease;
	}

	.news-link::before {
		content: "=>";
		font-size: 0.95rem;
	}

	.news-link:hover, .news-link:focus-visible, .news-list a:hover, .news-list a:focus-visible {
		/* text-decoration: underline; */
		transform: scale(1.01);
		color: #28678f;
	}

	.events-list {
		list-style: none;
		padding: 0;
		margin: 50px 0 0 0;
		display: grid;
		gap: 50px;
	}

	.events-list li {
		padding: 25px 50px 0;
		display: grid;
		grid-template-columns: 6rem 1fr;
		gap: 40px;
		align-items: start;
		border-top: 1px solid rgba(84, 70, 50, 0.3);
	}

	li .event-month {
		display: inline-block;
		opacity: 0;
		font-size: 1.75rem;
		letter-spacing: 0.05em;
		color: var(--color-text);
		text-decoration: none;
	}
	li .event-month:first-child {	
		opacity: 1;	
	}


	.event-body {
		margin-top: 40px;
	}

	.event-title {
		margin: 0 0 8px;
		font-size: 1rem;
		letter-spacing: 0.04em;
		color: var(--color-text);
	}

	.event-desc {
		margin: 0;
		font-size: 1rem;
		line-height: 1.9;
		color: var(--color-text);
	}
	

	.media {
		margin: 0;
		border-radius: 16px;
		overflow: hidden;
		/* aspect-ratio: 1280 / 853; */
		aspect-ratio: 800 /900;
	}

	.media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.media-overview img {
		object-position: center center;
	}

	.media-news img {
		object-position: center bottom;
	}

	.media-news {
		/* aspect-ratio: 800 /900; */
	}


	@media (max-width: 768px) {
		#overview, #news {
			grid-template-columns: 1fr;
		}

		#overview .info-text,
		#news .info-text {
			order: 0;
		}

		#overview .media,
		#news .media {
			order: 1;
		}

		.events-list li {
			grid-template-columns: 1fr;
			gap: 10px;
		}

		.event-month {
			font-size: 1.5rem;
		}
	}
</style>
